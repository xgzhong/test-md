    "element-plus": "^2.4.4",
    "marked": "^11.1.0",
    "pinia": "^3.0.4",
    "vditor": "^3.11.2",
    "vue": "^3.3.11",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^4.5.2",
    "typescript": "^6.0.2",
    "vite": "^5.0.8",
    "vue-tsc": "^3.2.6"
